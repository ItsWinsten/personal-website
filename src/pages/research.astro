---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getOrcidPublications } from '../lib/orcid-static-cache';

const ORCID_ID = '0009-0009-4644-0072';

const { publications, fetchError } = await getOrcidPublications(ORCID_ID);
---

<BaseLayout title="Research">
  <div class="page">
    <h1>Research</h1>
    
    <h2>Research Interests</h2>
    <p>
      My research focuses on automated testing for cyber-physical systems (CPS), including systems such as autonomous vehicles, drones, and robotics. These systems combine software with physical behavior, so failures can depend on how inputs, timing, and the environment interact.
    </p>

    <p>
      I develop methods for validating black-box CPS against formal requirements. In this setting, the tester can run the system and observe its inputs and outputs, but cannot inspect or modify the internal implementation. My work uses search-based software engineering, machine learning, and Signal Temporal Logic (STL) to generate test scenarios that expose requirement violations.
    </p>

    <p>
      Current research themes include:
    </p>
    <ul>
      <li><strong>Explicit output coverage:</strong> generating inputs that produce important output behaviors, including boundary cases and safety-critical responses.</li>
      <li><strong>Multi-requirement falsification:</strong> testing several STL requirements together to find failures caused by requirement interactions.</li>
      <li><strong>Continuous falsification:</strong> reusing testing knowledge across system versions so validation remains effective as the system evolves.</li>
    </ul>

    <p>
      The goal is to make CPS validation more scalable and systematic. This is especially important in safety-critical domains, where engineers need evidence that systems behave correctly across many operating conditions and requirement combinations.
    </p>

    <p>
      <strong>PhD Thesis:</strong> Scalable Falsification of Multi-Formula STL Requirements for Cyber-Physical System Validation (title subject 
      to change).
    </p>

    <h2>Current Research</h2>
    <p>
      I am a PhD Researcher at <a href="https://www.abo.fi/en/" target="_blank" rel="noopener noreferrer">Åbo Akademi University</a>,{' '}
      currently completing my degree in Computer Science. I am a maintainer of <a href="https://gitlab.abo.fi/stc/stgem2" target="_blank" rel="noopener noreferrer">stgem (system testing using generative models)</a>,{' '}
      an open-source Python framework for automated CPS test generation. STGEM supports falsification, corner-case generation, and requirement-driven testing. It combines search algorithms and generative models, including GANs, to find test cases that are difficult to discover manually.
    </p>
    
    <h2>Publications</h2>
    {fetchError && (
      <div class="notice">
        <p><strong>Note:</strong> {fetchError}</p>
        <p>Please update your ORCID ID.</p>
      </div>
    )}
    
    {publications.length > 0 ? (
      <div class="publications">
        {publications.map((pub) => (
          <div class="publication">
            <h3 class="pub-title">{pub.title}</h3>
            <div class="pub-meta">
              <span class="pub-year">{pub.year}</span>
              {pub.journal && <span class="pub-journal"> · {pub.journal}</span>}
              {pub.type && <span class="pub-type"> · {pub.type.replace(/-/g, ' ')}</span>}
            </div>
            {pub.url && (
              <div class="pub-links">
                <a href={pub.url} target="_blank" rel="noopener noreferrer">
                  View Publication →
                </a>
              </div>
            )}
          </div>
        ))}
      </div>
    ) : !fetchError && (
      <p><em>Loading publications from ORCID...</em></p>
    )}
    
    
    <h2>Research Links</h2>
    <div class="research-links">
      <a class="button" href="https://research.abo.fi/en/persons/jesper-winsten/" target="_blank" rel="noopener noreferrer">Research Profile (ÅAU)</a>
      <a class="button" href={`https://orcid.org/${ORCID_ID}`} target="_blank" rel="noopener noreferrer">ORCID Profile</a>
      <a class="button" href="https://scholar.google.com/citations?user=KbH2RR0AAAAJ&hl=fi&oi=ao" target="_blank" rel="noopener noreferrer">Google Scholar</a>
    </div>
  </div>
</BaseLayout>

<style>
  /* Page-specific styles for research publications */
  .publications {
    margin-top: 1.5rem;
  }

  .publication {
    margin-bottom: 2rem;
  }

  .pub-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.2rem;
    line-height: 1.4;
  }

  .pub-meta {
    color: var(--gray);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .pub-year {
    font-weight: bold;
  }

  .pub-type {
    text-transform: capitalize;
  }

  .pub-links {
    margin-top: 0.5rem;
  }

  .pub-links a {
    display: inline-block;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .pub-links a:hover {
    text-decoration: underline;
  }
</style>
