---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="winsten.dev">
  <div class="page">
    <div class="index-content">
      <div class="profile-intro">
        <img fetchpriority="high" src="/profile.webp" alt="Jesper Winsten" class="profile-image" />
        <div class="profile-summary">
          <h1 id="hello-there">Jesper Winsten</h1>
          <p class="profile-tagline">
            PhD Researcher | AI & Software Testing<br/>
            <a href="https://research.abo.fi/en/persons/jesper-winsten/">Åbo Akademi University</a>
          </p>
          <p>
            I develop AI-assisted testing methods for cyber-physical systems, with a focus on generating test cases that reveal requirement violations and safety-critical behavior.
          </p>
        </div>
      </div>
    </div>

    <section class="index-section">
      <h2>About Me</h2>
      <p>
        I am a PhD researcher in Computer Science at Åbo Akademi University. My work sits at the intersection of software engineering, machine learning, and safety validation for cyber-physical systems such as autonomous vehicles and robotics.
      </p>
      <p>
        I study how automated test generation can help engineers find failures earlier. In particular, I use search-based software engineering and generative models to produce test scenarios for black-box systems, where testers can observe inputs and outputs but not the system's internal implementation.
      </p>
    </section>

    <section class="index-section">
      <h2>Experience</h2>
      <div class="timeline-item">
        <div class="timeline-header">
          <h3>Åbo Akademi University</h3>
        </div>
        <div class="timeline-subtitle">
          <span>PhD Researcher</span>
          <span class="timeline-date">2022 - Present</span>
        </div>
        <p>Researching automated test generation for cyber-physical systems. My current work uses search-based methods and generative adversarial networks (GANs) to create test cases that expose requirement violations, edge cases, and unsafe behavior.</p>
      </div>
      
      <div class="timeline-item">
        <div class="timeline-header">
          <h3>Machine Learning Engineer</h3>
        </div>
        <div class="timeline-subtitle">
          <span>Everon Oy Ab</span>
          <span class="timeline-date">2022</span>
        </div>
        <p>
          Developed machine learning solutions for welfare technology. One project used pose detection to monitor client well-being on edge devices. The system kept raw camera data local and transmitted only anonymized pose vectors and events, such as falls or unusual inactivity, so caregivers could receive alerts without access to video feeds.
        </p>
      </div>
    </section>

    <section class="index-section">
      <h2>Education</h2>
      <div class="timeline-item">
        <div class="timeline-header">
          <h3>Åbo Akademi University</h3>
        </div>
        <div class="timeline-subtitle">
          <span>Doctor of Philosophy - PhD, Computer Science</span>
          <span class="timeline-date">2022 - Present</span>
        </div>
        <p>Research focus: automated testing and falsification of cyber-physical systems using search-based methods and generative models.</p>
      </div>
      
      <div class="timeline-item">
        <div class="timeline-header">
          <h3>Åbo Akademi University & Reykjavik University</h3>
        </div>
        <div class="timeline-subtitle">
          <span>Master of Science - MS, Computer Science</span>
          <span class="timeline-date">2020 - 2022</span>
        </div>
        <p>Double degree in the Nordic Master Programme in Intelligent Software Systems (NISS), completed at Åbo Akademi University and Reykjavik University. <br/><br/> <strong>Thesis: Deep learning approaches for ship detection from inshore and offshore imagery.</strong></p>
      </div>
      
      <div class="timeline-item">
        <div class="timeline-header">
          <h3>Åbo Akademi University</h3>
        </div>
        <div class="timeline-subtitle">
          <span>Bachelor of Science - BS, Computer Science</span>
          <span class="timeline-date">2017 - 2020</span>
        </div>
        <p>Minor studies: Biochemistry.</p>
        <p><strong>Thesis: Utilization of connection sequences for connecting devices to fake Wi-Fi networks.</strong></p>
      </div>
    </section>



  </div>
</BaseLayout>

<style>
  .profile-intro {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .profile-summary {
    flex: 1;
    min-width: 300px;
  }

  .profile-summary h1 {
    margin-top: 0;
  }

  .profile-tagline {
    font-size: 1.1rem;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .profile-image {
    margin-top: 0;
  }

  .index-section h2 {
    color: var(--accent);
    margin-top: 3rem;
    padding-top: 2rem;
    padding-bottom: 0.5rem;
    border-top: 2px solid var(--accent);
    font-size: 1.5rem;
  }

  .index-section + .index-section h2 {
    border-top: 2px solid var(--accent);
  }

  .timeline-item {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .timeline-item:last-child {
    border-bottom: none;
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.25rem;
  }

  .timeline-header h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--accent) 80%, transparent);
  }

  .timeline-date {
    color: var(--accent);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .timeline-subtitle {
    font-size: 1rem;
    color: var(--foreground);
    margin: 0.25rem 0 0.75rem 0;
    font-weight: 500;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .timeline-item p:last-child {
    margin-bottom: 0;
  }
</style>
